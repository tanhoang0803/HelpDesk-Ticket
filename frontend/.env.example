# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables
# Copy this file to .env.local for local development.
# For Vercel: set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── NextAuth ─────────────────────────────────────────────────────────────────
# The canonical URL of the deployed frontend.
# Vercel Preview deployments need NEXTAUTH_URL_INTERNAL or use VERCEL_URL.
# Example: https://helpdesk.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_THIS_TO_A_STRONG_32_CHAR_RANDOM_STRING

# ── Backend API ───────────────────────────────────────────────────────────────
# Your Railway backend URL (no trailing slash).
# This is injected at BUILD TIME — the Next.js client bundle bakes it in.
# Example: https://helpdesk-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001
