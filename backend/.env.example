# ─────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in real values before running.
# For Railway: set these in the Railway service's "Variables" tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL when you add a PostgreSQL service.
# Local: matches docker-compose.yml defaults (port 5433)
DATABASE_URL="postgresql://helpdesk:helpdesk_secret@localhost:5433/helpdesk_db?schema=public"

# ── Redis ────────────────────────────────────────────────────────────────────
# Railway auto-injects REDIS_URL when you add a Redis service.
# If using REDIS_URL, the app will parse host/port/password from it.
# Otherwise set individually:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong 64-char+ secrets for production.
# Example (Linux/Mac): openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_STRONG_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── Email (optional — tickets still work without valid SMTP) ─────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM="HelpDesk <no-reply@your-domain.com>"

# ── Server ───────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — do not override this in the dashboard.
PORT=3001
NODE_ENV=production
